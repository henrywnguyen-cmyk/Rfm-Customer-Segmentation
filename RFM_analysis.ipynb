   "source": [
    "### Revenue contribution by segment\n",
    "\n",
    "Champions are a small slice of customers but drive a disproportionate \n",
    "share of revenue — the core insight of RFM."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 58,
   "id": "7884e6ab",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1080x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "rev_by_seg = rfm.groupby('segment')['monetary'].sum().sort_values(ascending=False)\n",
    "rev_pct    = (rev_by_seg / rev_by_seg.sum() * 100).round(1)\n",
    "bar_colors2 = [colors[s] for s in rev_pct.index]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(9, 4))\n",
    "bars = ax.barh(rev_pct.index, rev_pct.values, color=bar_colors2, height=0.55)\n",
    "\n",
    "for bar, val in zip(bars, rev_pct.values):\n",
    "    ax.text(bar.get_width() + 0.4, bar.get_y() + bar.get_height()/2,\n",
    "            f'{val}%', va='center', fontsize=10)\n",
    "\n",
    "ax.set_xlabel('Share of total revenue (%)')\n",
    "ax.set_title('Revenue contribution by segment', fontsize=13, fontweight='bold', pad=12)\n",
    "ax.invert_yaxis()\n",
    "sns.despine()\n",
    "plt.tight_layout()\n",
    "plt.savefig('segment_revenue.png', bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a1951fac",
   "metadata": {},
   "source": [
    "### Recency vs Frequency scatter\n",
    "\n",
    "Champions cluster top-left (low recency, high frequency). \n",
    "Win Back sits bottom-right. The separation validates the scoring logic."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 59,
   "id": "625ca951",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1080x600 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "plot_df = rfm.copy()\n",
    "plot_df['freq_capped'] = plot_df['frequency'].clip(upper=10)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(9, 5))\n",
    "for seg, grp in plot_df.groupby('segment'):\n",
    "    ax.scatter(grp['recency'], grp['freq_capped'],\n",
    "               label=seg, alpha=0.4, s=14, color=colors[seg])\n",
    "\n",
