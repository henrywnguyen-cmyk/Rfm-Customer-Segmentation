import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import matplotlib.ticker as mticker
import seaborn as sns
from datetime import timedelta

sns.set_theme(style='whitegrid', palette='muted')
plt.rcParams['figure.dpi'] = 120

# ── 1. Setup & Data Loading ──────────────────────────────────────────────
df = pd.read_csv('orders_cleaned.csv', low_memory=False)
print(f"Loaded {len(df):,} rows across {df['Name'].nunique():,} order numbers")

# ── 2. Cleaning ───────────────────────────────────────────────────────────
clean = df[df['Financial Status'] == 'paid'].copy()
print(f"After paid filter:       {len(clean):,} rows")

clean = clean[clean['Cancelled at'].isna()]
print(f"After cancel drop:       {len(clean):,} rows")

clean = clean[clean['Email'].notna()]
print(f"After email drop:        {len(clean):,} rows")

orders = clean.drop_duplicates(subset='Name')[['Name', 'Email', 'Created at', 'Total', 'Refunded Amount']].copy()
print(f"After dedup (orders):    {len(orders):,} unique orders")

orders['Refunded Amount'] = orders['Refunded Amount'].fillna(0)
orders['net_total'] = orders['Total'] - orders['Refunded Amount']
orders = orders[orders['net_total'] > 0]
print(f"After net revenue > 0:   {len(orders):,} orders")

orders['Created at'] = pd.to_datetime(orders['Created at'], utc=True)
print(f"\nDate range:  {orders['Created at'].min().date()} → {orders['Created at'].max().date()}")
print(f"Unique customers: {orders['Email'].nunique():,}")

# ── 3. RFM Metrics ────────────────────────────────────────────────────────
snapshot = orders['Created at'].max() + timedelta(days=1)

rfm = orders.groupby('Email').agg(
    recency   = ('Created at', lambda x: (snapshot - x.max()).days),
    frequency = ('Name',       'nunique'),
    monetary  = ('net_total',  'sum')
).reset_index()

print(f"Snapshot date: {snapshot.date()}")
print(f"RFM table: {rfm.shape[0]:,} customers")
print(rfm[['recency', 'frequency', 'monetary']].describe().round(2))

# ── 4. Scoring (Quintiles 1–5) ────────────────────────────────────────────
rfm['R'] = pd.qcut(rfm['recency'],                        q=5, labels=[5,4,3,2,1], duplicates='drop')
rfm['F'] = pd.qcut(rfm['frequency'].rank(method='first'), q=5, labels=[1,2,3,4,5])
rfm['M'] = pd.qcut(rfm['monetary'],                       q=5, labels=[1,2,3,4,5], duplicates='drop')

rfm['rfm_score'] = rfm[['R', 'F', 'M']].astype(int).sum(axis=1)

print("Score distribution:")
print(rfm['rfm_score'].value_counts().sort_index())

# ── 5. Segmentation ───────────────────────────────────────────────────────
def label_segment(row):
    r, f = int(row.R), int(row.F)
    if   r >= 4 and f >= 4: return 'Champion'
    elif r >= 3 and f >= 3: return 'Loyal Customer'
    elif r >= 4 and f <= 2: return 'New Customer'
    elif r <= 2 and f >= 3: return 'At Risk'
    elif r == 1 and f >= 2: return 'Win Back'
    else:                   return 'One-Time Buyer'

rfm['segment'] = rfm.apply(label_segment, axis=1)
print(rfm['segment'].value_counts())

# ── 6. Segment Summary ────────────────────────────────────────────────────
summary = rfm.groupby('segment').agg(
    customers     = ('Email',     'count'),
    avg_recency   = ('recency',   'mean'),
    avg_frequency = ('frequency', 'mean'),
    avg_monetary  = ('monetary',  'mean'),
    total_revenue = ('monetary',  'sum')
).round(1)

summary['revenue_pct'] = (summary['total_revenue'] / summary['total_revenue'].sum() * 100).round(1)
print(summary.sort_values('total_revenue', ascending=False))

# ── 7. Visualisations ──────────────────────────────────────────────────────
colors = {
    'Champion':       '#1D9E75',
    'Loyal Customer': '#378ADD',
    'New Customer':   '#7F77DD',
    'At Risk':        '#D85A30',
    'Win Back':       '#E24B4A',
    'One-Time Buyer': '#888780'
}

# Customer count by segment
counts = rfm['segment'].value_counts()
bar_colors = [colors[s] for s in counts.index]

fig, ax = plt.subplots(figsize=(9, 4))
bars = ax.barh(counts.index, counts.values, color=bar_colors, height=0.55)

for bar, val in zip(bars, counts.values):
    ax.text(bar.get_width() + 80, bar.get_y() + bar.get_height()/2,
            f'{val:,}', va='center', fontsize=10)

ax.set_xlabel('Number of customers')
ax.set_title('Customer count by segment', fontsize=13, fontweight='bold', pad=12)
ax.invert_yaxis()
ax.xaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'{int(x):,}'))
sns.despine()
plt.tight_layout()
plt.savefig('segment_counts.png', bbox_inches='tight')
plt.show()

# Revenue contribution by segment
rev_by_seg = rfm.groupby('segment')['monetary'].sum().sort_values(ascending=False)
rev_pct    = (rev_by_seg / rev_by_seg.sum() * 100).round(1)
bar_colors2 = [colors[s] for s in rev_pct.index]

fig, ax = plt.subplots(figsize=(9, 4))
bars = ax.barh(rev_pct.index, rev_pct.values, color=bar_colors2, height=0.55)

for bar, val in zip(bars, rev_pct.values):
    ax.text(bar.get_width() + 0.4, bar.get_y() + bar.get_height()/2,
            f'{val}%', va='center', fontsize=10)

ax.set_xlabel('Share of total revenue (%)')
ax.set_title('Revenue contribution by segment', fontsize=13, fontweight='bold', pad=12)
ax.invert_yaxis()
sns.despine()
plt.tight_layout()
plt.savefig('segment_revenue.png', bbox_inches='tight')
plt.show()

# Recency vs Frequency scatter
plot_df = rfm.copy()
plot_df['freq_capped'] = plot_df['frequency'].clip(upper=10)

fig, ax = plt.subplots(figsize=(9, 5))
for seg, grp in plot_df.groupby('segment'):
    ax.scatter(grp['recency'], grp['freq_capped'],
               label=seg, alpha=0.4, s=14, color=colors[seg])

ax.set_xlabel('Recency (days since last order)')
ax.set_ylabel('Frequency (orders, capped at 10)')
ax.set_title('Recency vs Frequency by segment', fontsize=13, fontweight='bold', pad=12)
ax.legend(title='Segment', bbox_to_anchor=(1.01, 1), loc='upper left', fontsize=9)
sns.despine()
plt.tight_layout()
plt.savefig('rfm_scatter.png', bbox_inches='tight')
plt.show()

# RFM Heatmap — avg spend across R × F combinations
heatmap_data = rfm.groupby(['R', 'F'], observed=False)['monetary'].mean().unstack()

fig, ax = plt.subplots(figsize=(7, 5))
sns.heatmap(heatmap_data, annot=True, fmt='.0f', cmap='YlGn',
            linewidths=0.5, ax=ax, cbar_kws={'label': 'Avg spend ($)'})
ax.set_xlabel('Frequency score')
ax.set_ylabel('Recency score')
ax.set_title('Avg monetary value — R × F heatmap', fontsize=13, fontweight='bold', pad=12)
plt.tight_layout()
plt.savefig('rfm_heatmap.png', bbox_inches='tight')
plt.show()

# ── 9. Export ──────────────────────────────────────────────────────────────
output = rfm[['Email', 'recency', 'frequency', 'monetary', 'R', 'F', 'M', 'rfm_score', 'segment']].copy()
output['customer_id'] = ['CUST_' + str(i).zfill(5) for i in range(len(output))]
output = output.drop(columns='Email')
output = output[['customer_id', 'recency', 'frequency', 'monetary', 'R', 'F', 'M', 'rfm_score', 'segment']]

output.to_csv('rfm_segments.csv', index=False)
print(f"Exported rfm_segments.csv — {len(output):,} customers")
print(output.head())
